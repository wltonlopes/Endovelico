                <bind_vertex_input semantic="Liby_Market-mesh-map-0" input_semantic="TEXCOORD" input_set="0"/>
                <bind_vertex_input semantic="Liby_Market-mesh-map-1" input_semantic="TEXCOORD" input_set="1"/>
              </instance_material>
            </technique_common>
          </bind_material>
        </instance_geometry>
      </node>
    </visual_scene>
  </library_visual_scenes>
  <scene>
    <instance_visual_scene url="#Scene"/>
  </scene>
</COLLADA>