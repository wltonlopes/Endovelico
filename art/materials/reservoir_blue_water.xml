<?xml version="1.0" encoding="utf-8"?>
<material>
    <shader effect="model_water"/>
    <required_texture name="baseTex"/>
    <renderquery name="water_tex"/>
    <renderquery name="sky_cube"/>
    <renderquery name="sim_time"/>
    <!-- Movimento suave (quase parado) -->
    <uniform name="translation" value="0.0008 -0.0005"/>
    <!-- Brilho e reflexo -->
    <uniform name="shininess" value="12.0"/>
    <uniform name="specularStrength" value="0.6"/>
    <!-- Ondulação leve (piscina não tem ondas fortes) -->
    <uniform name="waviness" value="0.015"/>
    <!-- === COR PRINCIPAL DA PISCINA === -->
    <uniform name="waterTint" value="0.05 0.75 0.85"/>
    <!-- Azul turquesa piscina -->
    <uniform name="reflectionTint" value="0.4 0.85 0.95"/>
    <!-- Reflexo mais claro -->
    <!-- Força dos reflexos -->
    <uniform name="reflectionTintStrength" value="0.35"/>
    <!-- Transparência e profundidade -->
    <uniform name="murkiness" value="0.12"/>
    <!-- Baixo = água limpa -->
    <!-- Outros ajustes úteis -->
    <uniform name="fresnelPower" value="2.5"/>
    <uniform name="fresnelFactor" value="0.8"/>
</material>
